.page {
  min-height: 100vh;
  padding-bottom: 140rpx;
  background: #f7f3eb;
}

.artwork-img {
  width: 100%;
  height: 720rpx;
  background: #ddd;
}

.info-card {
  margin: 28rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background: #fff;
}

.title {
  font-size: 38rpx;
  font-weight: 700;
}

.artist-name {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #777;
}

price-growth-card {
  display: block;
  margin: 28rpx;
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 28rpx;
  background: #fff;
  box-shadow: 0 -8rpx 24rpx rgba(0,0,0,0.06);
}

.collect-btn {
  flex: 1;
  border-radius: 999rpx;
  background: #f5efe3;
  color: #7a5427;
}

.buy-btn {
  flex: 2;
  border-radius: 999rpx;
  background: #111;
  color: #fff;
}
